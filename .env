#PostgreSQL
PG_VERSION=16
PG_PORT=5432
PG_HOST=localhost
PG_CONTAINER=dbsm_postgres
POSTGRES_USER=dbsm_admin
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dbsm

#PgADMIN
PGADMIN_VERSION=9.2
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=user@domain.com
PGADMIN_DEFAULT_PASSWORD=postgres

#PostgREST
POSTGREST_VERSION=v12.2.8
POSTGREST_PORT=3000
PGRST_DB_AUTHENTICATOR_PASSWORD=postgres
PGRST_DB_ANON_ROLE=web_anon
PGRST_DB_SCHEMA=v1

#Swagger
SWAGGER_VERSION=v5.21.0
SWAGGER_PORT=8082

#GEOServer
GEOSERVER_VERSION=2.24.2
GEOSERVER_PORT=8081
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver
